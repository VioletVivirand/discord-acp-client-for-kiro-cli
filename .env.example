# Discord bot token (required)
DISCORD_TOKEN=

# Working directory for Kiro sessions (defaults to the bot's CWD)
KIRO_SESSION_CWD=

# Idle timeout before a per-thread Kiro subprocess is reaped (seconds)
KIRO_IDLE_TIMEOUT_SECONDS=300

# Path to the kiro-cli binary
KIRO_CLI_BIN=kiro-cli

# Default model for Kiro sessions (see `kiro-cli chat --list-models`; e.g. auto, claude-sonnet-4.5)
KIRO_MODEL=auto

# Agent (persona) to launch sessions with; defines the system prompt/tools.
# Create one with `kiro-cli agent create`; leave blank for the default agent.
KIRO_AGENT=

# Log file path
LOG_FILE=bot.log
